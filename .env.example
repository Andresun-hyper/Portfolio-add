# Public, non-secret admin origin. Use the deployed admin URL.
ADMIN_PUBLIC_ORIGIN=https://your-admin-site.netlify.app

# GitHub OAuth app for admin login.
ADMIN_GITHUB_CLIENT_ID=
ADMIN_GITHUB_CLIENT_SECRET=
ADMIN_ALLOWED_GITHUB_USER_ID=

# Long random secret used to hash opaque session ids before storing them.
ADMIN_SESSION_SECRET=

# Fine-grained PAT only for this repo with contents:write and pull_requests:write.
GITHUB_FINE_GRAINED_PAT=
GITHUB_REPO_OWNER=Andresun-hyper
GITHUB_REPO_NAME=
GITHUB_BASE_BRANCH=main

# Optional public preview target used by the admin iframe before a Deploy Preview exists.
VITE_PORTFOLIO_URL=https://andresun-hyper-portfolio.netlify.app/
